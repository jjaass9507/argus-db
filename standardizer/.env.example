# =============================================================================
# Argus-DB Standardizer — 設定範例
# 複製為 .env，填入實際值。.env 已被 .gitignore 排除，切勿提交真實憑證。
# =============================================================================

# Kafka (與 deploy/docker-compose 的 kafka 服務相同節點)
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_GROUP_ID=argus-standardizer
KAFKA_TOPIC_REGEX=^argus\.src\..+

# 稽核庫連線 (argus_writer 角色；密碼由 secret manager 注入，勿寫死)
# 生產環境: 建立 login-capable user 並 GRANT argus_writer TO that_user;
AUDIT_DB_DSN=postgresql://argus_writer_usr:CHANGE_ME@localhost:5432/argus_audit_db

# topic-prefix → managed_node.node_key 對應 (逗號分隔的 key=value)
TOPIC_PREFIX_NODE_MAP=argus.src.pg01=prod-pg-01,argus.src.mssql01=prod-mssql-01
