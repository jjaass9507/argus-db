# =============================================================================
# Argus-DB | Phase 0 部署設定範例
# 複製為 .env 後填入實際值。.env 已被 .gitignore 排除, 切勿提交真實憑證。
# =============================================================================

# --- 集中化稽核庫 (本地容器) ---
AUDIT_DB_USER=argus
AUDIT_DB_PASSWORD=change_me_in_real_deploy   # 生產環境改由 secret manager 注入
AUDIT_DB_NAME=argus_audit_db
AUDIT_DB_PORT=5432

# --- Kafka / Connect ---
KAFKA_PORT=9092
KAFKA_CLUSTER_ID=argus-phase0-cluster
CONNECT_PORT=8083

# --- 來源節點: PostgreSQL (供 connectors/postgres-source.json 套用) ---
SRC_PG_HOST=10.0.4.20
SRC_PG_PORT=5432
SRC_PG_DBNAME=app_db
SRC_PG_USER=debezium          # 需具 REPLICATION 權限
SRC_PG_PASSWORD=change_me

# --- 來源節點: MSSQL (供 connectors/mssql-source.json 套用) ---
SRC_MSSQL_HOST=10.0.4.12
SRC_MSSQL_PORT=1433
SRC_MSSQL_DBNAME=AppDb
SRC_MSSQL_USER=debezium
SRC_MSSQL_PASSWORD=change_me
