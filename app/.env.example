# =============================================================================
# Argus-DB 平台 API — 設定範例。複製為 .env 後填值。.env 不進 git。
# =============================================================================

# --- 開發模式 ---
# true：跳過真實 AD，回傳假身分，可於非 Windows 開發/測試 (登入密碼用 "mock")。
# 正式環境 (Windows IIS) 設為 false。
MOCK_AD=true
MOCK_AD_USER=K11879
MOCK_AD_GROUPS=DB-Viewers,IT-Admins

# --- AD / LDAP (MOCK_AD=false 時生效) ---
AD_SERVER=ldap://KH                    # NetBIOS 短名
AD_DOMAIN=kh.asegroup.com              # 完整網域
AD_BASE_DN=DC=kh,DC=asegroup,DC=com    # 搜尋根目錄 (可由網域推導)
AD_BIND_DN=                            # 服務帳號 (選填，查群組用)
AD_BIND_PW=

# --- Session ---
SECRET_KEY=change-me-to-a-long-random-string

# --- 診斷端點 (/debug/env)；上線前設為 false ---
ENABLE_DEBUG_ENDPOINTS=false
